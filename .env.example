# ---- Xiaohongshu login session (Stage 1+) ----
# Full cookie string from a logged-in xiaohongshu.com session (key fields: a1, web_session).
# In Multica, inject via the agent custom_env (`multica agent env set`), NOT this file.
# NEVER paste the cookie into issue comments.
XHS_COOKIE=

# Default keyword for scrape_all (Stage 3)
XHS_KEYWORD=

# ---- Feishu bitable ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
NOTE_TABLE_ID=
USER_TABLE_ID=
COMMENT_TABLE_ID=

# ---- Tuning ----
# XHS risk-control is stricter than Douyin; keep the delay conservative.
REQUEST_DELAY=3
MAX_PAGES=10
PROXY_URL=
